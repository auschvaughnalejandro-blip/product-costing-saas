# ─────────────────────────────────────────────────────────────
# Product Costing SaaS — environment configuration
# Copy this file to `.env` and fill in the values.
# The app runs fully WITHOUT the SAP and AI values; leave them
# blank until access / keys are granted.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL)
# Tip: set DATABASE_URL=pglite to run with a zero-setup in-process database
# (no Docker/Postgres needed) for a quick local try. Data is in-memory; use
# pglite:./.pgdata to persist to disk. Use a real PostgreSQL URL for anything real.
DATABASE_URL=postgresql://costing:costing@localhost:5432/costing
# Used by docker-compose to initialise the database container:
POSTGRES_USER=costing
POSTGRES_PASSWORD=costing
POSTGRES_DB=costing

# API server
# Port the API listens on. The frontend dev server (Vite) defaults to 5173 and
# proxies /api to this port — keep them distinct and free of other local apps.
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed browser origins for CORS. ALLOWED_ORIGIN is the
# preferred name; in production set it to your real domain only. (WEB_ORIGIN is
# still accepted as a fallback for older setups.)
ALLOWED_ORIGIN=http://localhost:5173
# Max accepted upload size in MB (sizes both multer and the JSON body parser).
MAX_UPLOAD_MB=50
# Secret used to sign auth tokens — set a long random value in production.
# (The app refuses to start in production while this is still the dev default.)
JWT_SECRET=dev-only-change-me-to-a-long-random-string
# How long an auth session lasts.
JWT_EXPIRES_IN=7d
# Run database migrations automatically on server start. Left false locally
# (run `npm run db:migrate`); the Docker image sets this to true.
MIGRATE_ON_START=false

# Frontend (Vite)
# Dev server port (default 5173). strictPort is on, so a conflict fails loudly.
VITE_PORT=5173
# Where the dev server proxies /api to (default http://localhost:3000).
VITE_DEV_API_PROXY=http://localhost:3000
# Base URL of the API as seen by the browser. Leave BLANK to use same-origin
# /api (proxied by Vite in dev and nginx in prod). Only set this when the API is
# on a different origin with no proxy in front of it.
VITE_API_URL=

# AI assistant (Google Gemini, via a swappable adapter)
# Leave AI_PROVIDER=gemini with a blank key to run in "explain unavailable" mode.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# SAP S/4HANA (optional — blank until the client grants access)
SAP_BASE_URL=
SAP_CLIENT=
SAP_USERNAME=
SAP_PASSWORD=
