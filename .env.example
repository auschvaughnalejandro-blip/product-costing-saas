# ─────────────────────────────────────────────────────────────
# Product Costing SaaS — environment configuration
# Copy this file to `.env` and fill in the values.
# The app runs fully WITHOUT the SAP and AI values; leave them
# blank until access / keys are granted.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL)
# Tip: set DATABASE_URL=pglite to run with a zero-setup in-process database
# (no Docker/Postgres needed) for a quick local try. Data is in-memory; use
# pglite:./.pgdata to persist to disk. Use a real PostgreSQL URL for anything real.
DATABASE_URL=postgresql://costing:costing@localhost:5432/costing
# Used by docker-compose to initialise the database container:
POSTGRES_USER=costing
POSTGRES_PASSWORD=costing
POSTGRES_DB=costing

# API server
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed browser origins for CORS.
WEB_ORIGIN=http://localhost:5173
# Secret used to sign auth tokens — set a long random value in production.
JWT_SECRET=dev-only-change-me-to-a-long-random-string
# How long an auth session lasts.
JWT_EXPIRES_IN=7d

# Frontend (Vite) — base URL of the API as seen by the browser
VITE_API_URL=http://localhost:3000

# AI assistant (Google Gemini, via a swappable adapter)
# Leave AI_PROVIDER=gemini with a blank key to run in "explain unavailable" mode.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# SAP S/4HANA (optional — blank until the client grants access)
SAP_BASE_URL=
SAP_CLIENT=
SAP_USERNAME=
SAP_PASSWORD=
